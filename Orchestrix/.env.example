# Orchestrix .env example

# Anthropic (Claude) API key — preferred LLM
ANTHROPIC_API_KEY=

# Pinecone for vector search (optional for RAG/KB)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=tk-policy

# Ollama local LLM base URL (optional fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Defaults
DEFAULT_MODEL=claude
RATE_LIMIT_RPM=20
ENABLE_SENTIMENT=true
ENABLE_TRANSLATION=true
AUDIT_LOG_PATH=logs/audit.jsonl
EMPLOYEE_DATA_PATH=employee_data.csv
HR_POLICY_PATH=hr_policy.txt
CANDIDATE_DB_PATH=data/candidates.db
