# ══════════════════════════════════════════════════════════════
# Orchestrix — Environment Variables
# Copy this file, rename the copy to just:  .env
# Fill in your values below.
# NEVER share this file — it contains your secret keys!
# ══════════════════════════════════════════════════════════════

# ── Anthropic Claude (FREE tier) ──────────────────────────────
# Sign up free at: https://console.anthropic.com
# Free tier = 5 million tokens/month — enough for ~100K HR queries
ANTHROPIC_API_KEY=sk-ant-PASTE-YOUR-KEY-HERE

# ── Pinecone Vector Database (FREE tier) ──────────────────────
# Sign up free at: https://app.pinecone.io
# Create an index named tk-policy, dimensions=384, metric=cosine
PINECONE_API_KEY=PASTE-YOUR-PINECONE-KEY-HERE
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=tk-policy

# ── Model Configuration ────────────────────────────────────────
# Keep this as "claude" — it uses the free Claude tier
DEFAULT_MODEL=claude

# ── Features ──────────────────────────────────────────────────
ENABLE_SENTIMENT=false
ENABLE_TRANSLATION=true

# ── Authentication ─────────────────────────────────────────────
# Keep as false for now
AUTH_ENABLED=false
